{
  "name": "learnfromus-server",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "migrate": "node src/migrate.js",
    "dev": "nodemon src/index.js",
    "start": "node src/index.js"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ignore": [
      "data/**",
      ".tmp-server-out.log",
      ".tmp-server-err.log"
    ],
    "ext": "js,json"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "duckdb": "^1.4.4",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "nodemailer": "^8.0.2",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
